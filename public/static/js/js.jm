<script id="PRODUCT-M-2">
    $('.goods-imgs .cover').click(function(){
        var src = $(this).attr('src');
        $('#show-img').attr('src',src);
        $(this).addClass('activate').siblings().removeClass('activate');
    });

    $('.icon-xiala').click(function(){
        $(this).parent().hide();
        $(this).parent().siblings().show();
    })

    $('.icon-shangla1').click(function(){

        $(this).parents('.hide-not').hide();
        $(this).parents('.hide-not').siblings().show();
    })

    $(document).ready(function() {
        const carouselSlide = $('.img-slide');
        const images = $('.img-slide img');
        const totalImages = images.length;
        let counter = 0;

        function slideImage() {
            counter++;
            if (counter >= totalImages) {
                counter = 0;
            }
            carouselSlide.css('transform', 'translateX(' + (-counter * 50) + '%)');
        }

        setInterval(slideImage, 8000);

        let startX, endX;

        $('.shop-img').on('touchstart', function(e) {
            startX = e.originalEvent.touches[0].pageX;
        });

        $('.shop-img').on('touchmove', function(e) {
            endX = e.originalEvent.touches[0].pageX;
        });

        $('.img-slide').on('touchend', function() {

            if (startX > endX + 1) {
                counter++;
                if (counter >= totalImages) {
                    counter = 0;
                }
            } else if (startX < endX - 1) {
                counter--;
                if (counter < 0) {
                    counter = totalImages - 1;
                }
            }
            carouselSlide.css('transform', 'translateX(' + (-counter * 50) + '%)');
        });
    });

    $(window).on('scroll', function() {
        $('.product-box').each(function() {
            var elementTop = $(this).offset().top;
            var viewportHeight = $(window).height();
            var scrollTop = $(window).scrollTop();
            var triggerPoint = viewportHeight * 0.3;

            if ((elementTop - scrollTop) <= triggerPoint) {
                $(this).find('.secret .packageleft .stamp-text').addClass('stamp-text-show');
            }
        });
    });
</script>


 <script id="CHECKOUT-M-1">

     var freight_where = parseInt('{{ $freight_where }}');

     var freight_price = parseInt('{{ $freight_price }}');


     $(".form-input").focus(function(){
         if(!$(this).hasClass(focus)){
             $(this).addClass('focus');
         }

     })
     $(".form-input").blur(function(){
         if(!$(this).val()){
             $(this).removeClass('focus');

         }


     });
     $('.label').click(function(){
         $(this).prev().focus();
     })

     $('input[name="order_type"]').click(function(){
         if($(this).val()>0){
             $('#rel-order-type').text("取貨付款");
         }else{
             $('#rel-order-type').text("貨到付款");
         }

     })

     var id,name,price,img,original_price;
     $('body').on('click','.goods-sku a',function(){
         id = $(this).attr('data-id');
         name = $(this).attr('data-name');
         price = $(this).attr('data-price');
         img = $(this).attr('data-img');
         original_price = $(this).attr('data-original');
         $('.goods-template-goods-img .goods-img').attr('src',img);
         $('.goods-template-title').text(name)
         $('.goods-template-red-price').text('優惠價：NT$ '+toThousands(price));

         $(this).addClass('article').parent().siblings().find('a').removeClass('article');
     });
     $('.goods-affirm').click(function(){
         $('.goods-img').attr('src',img);
         $('.goods-title').text(name)
         $('#goods-price').text(toThousands(original_price));

         $('#discount-price').text(toThousands(original_price-price));

         var freight = 0;
         if(price>=freight_where){
             $('#freight-price').text('NT$ 0')
         }else{
             freight = freight_price
             $('#freight-price').text('NT$ '+freight_price)
         }

         $('#order-price,#foot-order-price').text(toThousands(parseInt(price)+parseInt(freight)));

         $('.sku-main').removeClass('inshow')

         $('input[name="goods_id"]').val(id);

     });

     function toThousands(num) {
         var result = [],
             counter = 0
         num = (num || 0).toString().split('')
         for (var i = num.length - 1; i >= 0; i--) {
             counter++
             result.unshift(num[i])
             if (!(counter % 3) && i != 0) {
                 result.unshift(',')
             }
         }
         return result.join('')
     }

     $(document).ready(function() {
         setTimeout(function() {
             $('.stamp-text').addClass('stamp-text-show');
         }, 1000);

         $(".form-control").blur(function(){
             if($(this).val()){
                 $(this).addClass('focus');
                 $(this).siblings('svg').addClass('valid');
             }else{
                 $(this).removeClass('focus');
                 $(this).siblings('svg').removeClass('valid');
             }
         });
     });


     var submitValidate = function () {
         var name = $("input[name='name']").val();
         var phone = $("input[name='phone']").val();
         var email = $("input[name='email']").val();
         var city = $("select[name='city']").val();
         var county = $("select[name='county']").val();
         var street = $("select[name='street']").val();
         var address = $("input[name='address']").val();
         var order_type = $("input[name='order_type']:checked").val();
         var store_id = $("input[name='store_id']:checked").val();




         if(!name){
             error_message('請輸入姓名');
             return false;
         }

         if(!phone){
             error_message('請輸入電話');
             return false;
         }
         phone = phone.replaceAll('-','');
         if(!(/^09\d{8}$/.test(phone))){
             error_message('電話格式錯誤');
             return false;
         }

         if(!email){
             error_message('請輸入郵箱');
             return false;
         }

         if(!validateEmail(email)){
             error_message('郵箱格式錯誤');
             return false;
         }

         if(!city){
             error_message('請選擇縣市');
             return false;
         }

         if(!county){
             error_message('請選擇地區');
             return false;
         }
         if(!street){
             error_message('請選擇路段');
             return false;
         }

         if(order_type > 0 && !store_id){
             error_message('請選擇門市');
             return false;
         }else if(order_type <= 0 && !address){
             error_message('請填寫宅配地址');
             return false;
         }

         addLoadingActionBtn('.form-btn');

         return true;
     }

     function error_message(message){
         Swal.fire({
             icon:'error',
             iconColor:'#fff',
             text: message,
             color:'#fff',
             background:'rgba(0,0,0,0.7)',
             width:'auto',
             backdrop:false,
             timer:1000,
             timerProgressBar:false,
             showConfirmButton:false,
         })
     }

     var time_zone = Intl.DateTimeFormat().resolvedOptions().timeZone;
     $('input[name="timezone"]').val(time_zone);

     $('input[name="phone"]').on('input',function () {
         var str = $(this).val();
         str = str.replaceAll('-','');
         str = str.replaceAll(' ','');
         str = str.replace(/[^\d]/g, "");
         var arr = str.split('')

         if(arr.length > 4){
             str = str.slice(0,4)+'-'+str.slice(4);
         }
         if(arr.length > 7){
             str = str.slice(0,8)+'-'+str.slice(8);
         }
         $(this).val(str.slice(0,12));

     })
 </script>